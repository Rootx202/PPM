# PPM Environment Configuration Example
# Copy this file to .env and fill in your values

# Override default PyPI index URL
PPM_INDEX_URL=https://pypi.org/simple

# Comma-separated fallback mirror URLs
PPM_FALLBACK_MIRRORS=https://pypi.tuna.tsinghua.edu.cn/simple,https://mirrors.aliyun.com/pypi/simple

# Wheelhouse directory path (default: ~/.ppm/wheelhouse)
PPM_WHEELHOUSE_DIR=

# Log level: DEBUG, INFO, WARNING, ERROR
PPM_LOG_LEVEL=INFO

# Request timeout in seconds
PPM_TIMEOUT=30

# Maximum retry attempts
PPM_MAX_RETRIES=3

# Enable offline mode (true/false)
PPM_OFFLINE=false
